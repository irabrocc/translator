{
  "extends": "./tsconfig.main.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist/renderer",
    "rootDir": "src/renderer"
  },
  "include": ["src/renderer/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
